---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.tsx';

const pageTitle = "CrossMind Product Demo | See AI Cofounder in Action";
const pageDescription = "Watch CrossMind automate growth operations: social media management, content creation, analytics, and user acquisition - all autonomous.";
---

<Layout
	title={pageTitle}
	description={pageDescription}
	ogType="video.other"
>
	<Navbar client:load />

	<main class="min-h-screen bg-gradient-to-br from-gray-900 via-purple-900 to-gray-900 text-white">
		<div class="container mx-auto px-4 py-20 max-w-5xl">
			<!-- Header -->
			<div class="text-center mb-12">
				<h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
					Product Demo
				</h1>
				<p class="text-xl text-gray-300 max-w-2xl mx-auto">
					See how CrossMind automates social media, content creation, and growth operations — autonomously.
				</p>
			</div>

			<!-- Video Player -->
			<div class="bg-gray-800/50 backdrop-blur-sm rounded-2xl p-6 shadow-2xl border border-gray-700">
				<div class="aspect-video bg-black rounded-lg overflow-hidden">
					<video
						controls
						class="w-full h-full"
						poster="/product-tour-poster.jpg"
						preload="metadata"
					>
						<source src="/product-tour.mp4" type="video/mp4">
						Your browser does not support the video tag.
					</video>
				</div>

				<!-- Video Info -->
				<div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
					<div class="bg-gray-900/50 rounded-lg p-4">
						<div class="text-2xl font-bold text-blue-400 mb-1">2 min</div>
						<div class="text-sm text-gray-400">Demo Duration</div>
					</div>
					<div class="bg-gray-900/50 rounded-lg p-4">
						<div class="text-2xl font-bold text-purple-400 mb-1">Real Usage</div>
						<div class="text-sm text-gray-400">Actual Workflows</div>
					</div>
					<div class="bg-gray-900/50 rounded-lg p-4">
						<div class="text-2xl font-bold text-pink-400 mb-1">Meta-Proof</div>
						<div class="text-sm text-gray-400">Built by CrossMind</div>
					</div>
				</div>
			</div>

			<!-- Key Features Highlighted -->
			<div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="bg-gradient-to-br from-blue-500/10 to-blue-600/10 border border-blue-500/20 rounded-xl p-6">
					<h3 class="text-xl font-bold mb-3 text-blue-400">🚀 Social Automation</h3>
					<p class="text-gray-300">
						X/LinkedIn posting, replies, DMs, and engagement tracking — all autonomous with rate limiting and privacy handling.
					</p>
				</div>

				<div class="bg-gradient-to-br from-purple-500/10 to-purple-600/10 border border-purple-500/20 rounded-xl p-6">
					<h3 class="text-xl font-bold mb-3 text-purple-400">✍️ Content Creation</h3>
					<p class="text-gray-300">
						Blog posts, social threads, landing page copy — generated in your brand voice with SEO optimization.
					</p>
				</div>

				<div class="bg-gradient-to-br from-pink-500/10 to-pink-600/10 border border-pink-500/20 rounded-xl p-6">
					<h3 class="text-xl font-bold mb-3 text-pink-400">🔍 Competitive Intel</h3>
					<p class="text-gray-300">
						Monitor competitors' pricing, messaging, and launches. Browser-based research bypasses API limitations.
					</p>
				</div>

				<div class="bg-gradient-to-br from-green-500/10 to-green-600/10 border border-green-500/20 rounded-xl p-6">
					<h3 class="text-xl font-bold mb-3 text-green-400">📊 Analytics & Tracking</h3>
					<p class="text-gray-300">
						Task execution logs, performance metrics, engagement tracking — all in structured, queryable artifacts.
					</p>
				</div>
			</div>

			<!-- CTA Section -->
			<div class="mt-16 text-center bg-gradient-to-r from-blue-600/20 to-purple-600/20 border border-blue-500/30 rounded-2xl p-8">
				<h2 class="text-3xl font-bold mb-4">Ready to Try CrossMind?</h2>
				<p class="text-xl text-gray-300 mb-6 max-w-2xl mx-auto">
					Join the early access waitlist. We're onboarding 10-15 technical founders for beta testing.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href="/#waitlist"
						class="px-8 py-3 bg-gradient-to-r from-blue-500 to-purple-500 rounded-lg font-semibold hover:from-blue-600 hover:to-purple-600 transition-all"
					>
						Join Waitlist
					</a>
					<a
						href="/features"
						class="px-8 py-3 bg-gray-800 border border-gray-700 rounded-lg font-semibold hover:bg-gray-700 transition-all"
					>
						Explore Features
					</a>
				</div>
			</div>

			<!-- Meta-Proof -->
			<div class="mt-12 p-6 bg-yellow-500/10 border border-yellow-500/20 rounded-xl">
				<div class="flex items-start gap-4">
					<div class="text-3xl">🤖</div>
					<div>
						<h4 class="font-bold text-yellow-400 mb-2">Meta-Proof: Built by CrossMind</h4>
						<p class="text-gray-300 text-sm">
							This demo, the landing page, and all marketing materials were created by CrossMind itself.
							Real usage: <strong>60+ DMs sent</strong>, <strong>1 partnership secured</strong>, <strong>3 blog posts published</strong>,
							<strong>20+ social posts</strong> — all autonomous.
						</p>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	import { posthog } from '../lib/posthog';

	// Track demo page view
	posthog.capture('demo_page_viewed');

	// Track video interactions
	document.addEventListener('DOMContentLoaded', () => {
		const video = document.querySelector('video');
		if (video) {
			let hasTrackedPlay = false;
			let hasTracked25 = false;
			let hasTracked50 = false;
			let hasTracked75 = false;
			let hasTrackedComplete = false;

			video.addEventListener('play', () => {
				if (!hasTrackedPlay) {
					posthog.capture('demo_video_started');
					hasTrackedPlay = true;
				}
			});

			video.addEventListener('timeupdate', () => {
				const percent = (video.currentTime / video.duration) * 100;

				if (percent >= 25 && !hasTracked25) {
					posthog.capture('demo_video_progress_25');
					hasTracked25 = true;
				}
				if (percent >= 50 && !hasTracked50) {
					posthog.capture('demo_video_progress_50');
					hasTracked50 = true;
				}
				if (percent >= 75 && !hasTracked75) {
					posthog.capture('demo_video_progress_75');
					hasTracked75 = true;
				}
			});

			video.addEventListener('ended', () => {
				if (!hasTrackedComplete) {
					posthog.capture('demo_video_completed');
					hasTrackedComplete = true;
				}
			});
		}

		// Track CTA clicks
		const waitlistCTA = document.querySelector('a[href="/#waitlist"]');
		const featuresCTA = document.querySelector('a[href="/features"]');

		if (waitlistCTA) {
			waitlistCTA.addEventListener('click', () => {
				posthog.capture('demo_cta_clicked', { cta_type: 'waitlist' });
			});
		}

		if (featuresCTA) {
			featuresCTA.addEventListener('click', () => {
				posthog.capture('demo_cta_clicked', { cta_type: 'features' });
			});
		}
	});
</script>

<style>
	video::-webkit-media-controls-panel {
		background-image: linear-gradient(transparent, rgba(0,0,0,0.5));
	}
</style>
