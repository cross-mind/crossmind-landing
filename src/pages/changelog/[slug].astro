---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const changelogs = await getCollection('changelog', ({ data }) => !data.draft);
  return changelogs.map((entry) => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('changelog', slug as string);

if (!entry) {
  return Astro.redirect('/changelog');
}

const { Content } = await entry.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const categoryColors = {
  features: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
  improvements: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  fixes: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  performance: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  documentation: 'bg-gray-500/20 text-gray-400 border-gray-500/30',
};

const categoryIcons = {
  features: '✨',
  improvements: '🔧',
  fixes: '🐛',
  performance: '⚡',
  documentation: '📝',
};

// Get related changelogs
const allChangelogs = await getCollection('changelog', ({ data }) => !data.draft);
const relatedChangelogs = allChangelogs
  .filter(c => c.slug !== slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout
  title={`${entry.data.title} | CrossMind Changelog`}
  description={entry.data.description}
  ogType="article"
>
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-black/60 backdrop-blur-xl border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3 group">
          <svg viewBox="0 0 200 200" fill="none" width="28" height="28" class="transform group-hover:scale-110 transition-transform">
            <polygon points="28,22 54,22 108,84 100,100 92,84" fill="#2D5BFF"></polygon>
            <polygon points="92,116 100,100 108,116 172,178 146,178" fill="#2D5BFF"></polygon>
            <polygon points="54,22 74,40 108,84" fill="#1A3FC7" opacity="0.7"></polygon>
            <polygon points="172,178 172,160 108,116" fill="#1A3FC7" opacity="0.7"></polygon>
            <polygon points="172,22 146,22 92,84 100,100 108,84" fill="#00D4FF"></polygon>
            <polygon points="108,116 100,100 92,116 28,178 54,178" fill="#00D4FF"></polygon>
            <polygon points="146,22 126,40 92,84" fill="#00939B" opacity="0.65"></polygon>
            <polygon points="28,178 28,160 92,116" fill="#00939B" opacity="0.65"></polygon>
          </svg>
          <span class="text-lg font-bold text-white">CrossMind</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/#what-i-do" class="text-gray-400 hover:text-white transition-colors text-sm font-medium">What I do</a>
          <a href="/blog" class="text-gray-400 hover:text-white transition-colors text-sm font-medium">Blog</a>
          <a href="/changelog" class="text-white text-sm font-medium">Changelog</a>
          <a href="/#waitlist" class="bg-gradient-to-r from-[#2D5BFF] to-[#00D4FF] text-white px-5 py-2 rounded-full text-sm font-semibold hover:shadow-lg hover:shadow-[#2D5BFF]/50 transition-all transform hover:scale-105">
            Join Waitlist
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://crossmind.io"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Changelog",
        "item": "https://crossmind.io/changelog"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": entry.data.title,
        "item": `https://crossmind.io/changelog/${slug}`
      }
    ]
  })} />

  <main class="min-h-screen bg-black text-white pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <!-- Breadcrumb Navigation -->
      <nav class="flex items-center gap-2 text-xs text-gray-500 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/changelog" class="hover:text-white transition-colors">Changelog</a>
        <span>/</span>
        <span class="text-gray-400">{entry.data.title.substring(0, 40)}{entry.data.title.length > 40 ? '...' : ''}</span>
      </nav>

      <!-- Back link -->
      <a href="/changelog" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-white transition-colors mb-10" aria-label="Back to all updates">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All updates
      </a>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <time class="text-sm text-gray-500" datetime={entry.data.pubDate.toISOString()}>
            {formatDate(entry.data.pubDate)}
          </time>
          {entry.data.version && (
            <span class="text-xs px-2 py-1 rounded-full bg-white/10 text-gray-400 font-mono">
              {entry.data.version}
            </span>
          )}
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold leading-snug mb-4">{entry.data.title}</h1>
        <p class="text-gray-400 text-base mb-4">{entry.data.description}</p>

        {entry.data.categories.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {entry.data.categories.map(cat => (
              <span class={`text-xs px-3 py-1 rounded-full border ${categoryColors[cat]} font-medium`}>
                {categoryIcons[cat]} {cat.charAt(0).toUpperCase() + cat.slice(1)}
              </span>
            ))}
          </div>
        )}
      </div>

      <hr class="border-white/10 mb-10" />

      <!-- Content with changelog-specific styling -->
      <article class="prose prose-invert prose-sm sm:prose-base max-w-none
        prose-headings:font-semibold prose-headings:text-white
        prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-4 prose-h2:flex prose-h2:items-center prose-h2:gap-2
        prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-3
        prose-p:text-gray-300 prose-p:leading-relaxed prose-p:mb-4
        prose-ul:my-4 prose-ul:space-y-2
        prose-li:text-gray-300 prose-li:leading-relaxed
        prose-strong:text-white prose-strong:font-semibold
        prose-code:text-emerald-400 prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        prose-pre:bg-white/5 prose-pre:border prose-pre:border-white/10
        prose-hr:border-white/10 prose-hr:my-8
        prose-a:text-[#00D4FF] prose-a:no-underline hover:prose-a:text-white hover:prose-a:underline">
        <Content />
      </article>

      <!-- GitHub link -->
      <div class="mt-12 p-4 rounded-xl border border-white/10 bg-white/5">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span class="text-sm text-gray-400">View commit history on GitHub</span>
          </div>
          <a href="https://github.com/cross-mind/lumina-lab-agent/commits" target="_blank" rel="noopener" class="text-sm text-[#00D4FF] hover:text-white transition-colors font-medium">
            View commits →
          </a>
        </div>
      </div>

      <!-- Recent Updates -->
      {relatedChangelogs.length > 0 && (
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-white mb-6">Recent Updates</h2>
          <div class="space-y-4">
            {relatedChangelogs.map(related => (
              <a href={`/changelog/${related.slug}`} class="group block p-4 rounded-xl border border-white/10 bg-white/5 hover:border-emerald-500/40 hover:bg-white/8 transition-all">
                <div class="flex items-center gap-3 mb-2">
                  <time class="text-xs text-gray-500" datetime={related.data.pubDate.toISOString()}>
                    {formatDate(related.data.pubDate)}
                  </time>
                  {related.data.version && (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-white/10 text-gray-400 font-mono">
                      {related.data.version}
                    </span>
                  )}
                </div>
                <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-emerald-400 transition-colors">
                  {related.data.title}
                </h3>
                <p class="text-gray-400 text-sm">{related.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-16 p-6 rounded-2xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/10 to-blue-500/5 text-center">
        <p class="text-white font-semibold mb-2">Want to be part of the journey?</p>
        <p class="text-gray-400 text-sm mb-5">CrossMind is evolving fast. Join the waitlist to get early access.</p>
        <a href="/#waitlist" class="inline-block bg-gradient-to-r from-[#2D5BFF] to-[#00D4FF] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:shadow-lg hover:shadow-[#2D5BFF]/50 transition-all">
          Join Waitlist
        </a>
      </div>

    </div>
  </main>
</Layout>
