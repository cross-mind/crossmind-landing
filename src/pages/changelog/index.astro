---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const changelogs = (await getCollection('changelog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const categoryColors = {
  features: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
  improvements: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  fixes: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  performance: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  documentation: 'bg-gray-500/20 text-gray-400 border-gray-500/30',
};

const categoryIcons = {
  features: '✨',
  improvements: '🔧',
  fixes: '🐛',
  performance: '⚡',
  documentation: '📝',
};
---

<Layout
  title="Changelog - Platform Updates | CrossMind"
  description="Track CrossMind platform updates, new features, improvements, and bug fixes. See what we're building and how the AI cofounder evolves."
  ogType="website"
>
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-black/60 backdrop-blur-xl border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3 group">
          <svg viewBox="0 0 200 200" fill="none" width="28" height="28" class="transform group-hover:scale-110 transition-transform">
            <polygon points="28,22 54,22 108,84 100,100 92,84" fill="#2D5BFF"></polygon>
            <polygon points="92,116 100,100 108,116 172,178 146,178" fill="#2D5BFF"></polygon>
            <polygon points="54,22 74,40 108,84" fill="#1A3FC7" opacity="0.7"></polygon>
            <polygon points="172,178 172,160 108,116" fill="#1A3FC7" opacity="0.7"></polygon>
            <polygon points="172,22 146,22 92,84 100,100 108,84" fill="#00D4FF"></polygon>
            <polygon points="108,116 100,100 92,116 28,178 54,178" fill="#00D4FF"></polygon>
            <polygon points="146,22 126,40 92,84" fill="#00939B" opacity="0.65"></polygon>
            <polygon points="28,178 28,160 92,116" fill="#00939B" opacity="0.65"></polygon>
          </svg>
          <span class="text-lg font-bold text-white">CrossMind</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/#what-i-do" class="text-gray-400 hover:text-white transition-colors text-sm font-medium">What I do</a>
          <a href="/blog" class="text-gray-400 hover:text-white transition-colors text-sm font-medium">Blog</a>
          <a href="/changelog" class="text-white text-sm font-medium">Changelog</a>
          <a href="/#waitlist" class="bg-gradient-to-r from-[#2D5BFF] to-[#00D4FF] text-white px-5 py-2 rounded-full text-sm font-semibold hover:shadow-lg hover:shadow-[#2D5BFF]/50 transition-all transform hover:scale-105">
            Join Waitlist
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Page body -->
  <main class="min-h-screen bg-black text-white pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-16">
        <p class="text-sm text-emerald-400 font-semibold uppercase tracking-widest mb-3">Changelog</p>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
          What We're Building
        </h1>
        <p class="text-gray-400 text-lg">Follow CrossMind's evolution. New updates every 2 days. All changes tracked from our <a href="https://github.com/cross-mind/lumina-lab-agent" target="_blank" rel="noopener" class="text-[#00D4FF] hover:text-white transition-colors">open development</a>.</p>
      </div>

      <!-- Changelog entries -->
      {changelogs.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-gray-500 text-lg mb-4">No updates yet. First changelog coming soon.</p>
          <a href="https://github.com/cross-mind/lumina-lab-agent" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-[#00D4FF] hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Watch on GitHub
          </a>
        </div>
      ) : (
        <div class="space-y-12">
          {changelogs.map((entry) => (
            <article class="relative">
              <!-- Timeline dot -->
              <div class="absolute left-0 top-2 w-3 h-3 rounded-full bg-gradient-to-r from-[#2D5BFF] to-[#00D4FF] shadow-lg shadow-[#2D5BFF]/50"></div>

              <div class="pl-8 border-l-2 border-white/10 pb-8">
                <!-- Header -->
                <div class="mb-4">
                  <div class="flex items-center gap-3 mb-2">
                    <time class="text-sm text-gray-500" datetime={entry.data.pubDate.toISOString()}>
                      {formatDate(entry.data.pubDate)}
                    </time>
                    {entry.data.version && (
                      <span class="text-xs px-2 py-1 rounded-full bg-white/10 text-gray-400 font-mono">
                        {entry.data.version}
                      </span>
                    )}
                  </div>
                  <h2 class="text-2xl font-bold text-white mb-2">
                    <a href={`/changelog/${entry.slug}`} class="hover:text-[#00D4FF] transition-colors">
                      {entry.data.title}
                    </a>
                  </h2>
                  <p class="text-gray-400">{entry.data.description}</p>
                </div>

                <!-- Categories -->
                {entry.data.categories.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {entry.data.categories.map(cat => (
                      <span class={`text-xs px-3 py-1 rounded-full border ${categoryColors[cat]} font-medium`}>
                        {categoryIcons[cat]} {cat.charAt(0).toUpperCase() + cat.slice(1)}
                      </span>
                    ))}
                  </div>
                )}

                <!-- Read more -->
                <a href={`/changelog/${entry.slug}`} class="inline-flex items-center gap-2 text-sm text-[#2D5BFF] hover:text-[#00D4FF] transition-colors font-medium">
                  View details
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}

      <!-- Footer CTA -->
      <div class="mt-20 p-8 rounded-2xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/10 to-blue-500/5">
        <div class="text-center">
          <p class="text-white font-semibold text-lg mb-2">Building in public</p>
          <p class="text-gray-400 text-sm mb-6">Every update brings CrossMind closer to being the cofounder you need. Want early access?</p>
          <a href="/#waitlist" class="inline-block bg-gradient-to-r from-[#2D5BFF] to-[#00D4FF] text-white px-6 py-3 rounded-full text-sm font-semibold hover:shadow-lg hover:shadow-[#2D5BFF]/50 transition-all">
            Join the Waitlist
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
